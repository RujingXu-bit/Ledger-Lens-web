# Server-only backend origin. Never prefix this variable with NEXT_PUBLIC_.
API_BASE_URL=http://127.0.0.1:8000

# Canonical browser origin used for write-request Origin validation.
APP_ORIGIN=http://localhost:3000

# Production always forces Secure cookies. This local-only escape hatch supports
# browsers that reject Secure cookies on plain HTTP loopback addresses.
SESSION_COOKIE_SECURE=false

# Production deployment notes:
# - configure API_BASE_URL and APP_ORIGIN only in the Vercel dashboard;
# - omit SESSION_COOKIE_SECURE so production keeps Secure cookies;
# - set ENABLE_EXPERIMENTAL_COREPACK=1 for the packageManager pin.
